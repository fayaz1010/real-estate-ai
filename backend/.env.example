# Server Configuration
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/realestate_db?schema=public"

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_refresh_token_secret_here
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Email (SMTP Configuration)
# For development: Use Mailtrap (https://mailtrap.io) - free tier captures emails safely
# For production: Use SendGrid, Mailgun, or AWS SES
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_mailtrap_username
SMTP_PASS=your_mailtrap_password
SMTP_FROM_NAME="RealEstateAI"
SMTP_FROM_EMAIL=noreply@realestateai.com

# Email Rate Limiting (per recipient)
EMAIL_RATE_LIMIT_WINDOW_MS=3600000
EMAIL_RATE_LIMIT_MAX=10

# 2FA
TWO_FACTOR_AUTHENTICATION_APP_NAME="RealEstateAI"

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000 // 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3000

# Session
SESSION_SECRET=your_session_secret_here

# File Uploads
MAX_FILE_UPLOAD_SIZE=5 // in MB
UPLOAD_PATH=./uploads

# Logging
LOG_LEVEL=debug
LOG_TO_FILE=true
LOG_FILE_PATH=logs/app.log

# API Documentation
SWAGGER_ENABLED=true

# Security
SECURITY_CSRF_ENABLED=true
SECURITY_CSP_ENABLED=true
SECURITY_HSTS_ENABLED=true
SECURITY_XSS_ENABLED=true

# Cache
CACHE_ENABLED=true
CACHE_TTL=3600 // 1 hour

# Feature Flags
FEATURE_EMAIL_VERIFICATION=true
FEATURE_PHONE_VERIFICATION=false
FEATURE_2FA=false

# External Services
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
