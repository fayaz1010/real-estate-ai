# Server Configuration
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/realestate_db?schema=public"

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_refresh_token_secret_here
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Email Service (SendGrid API — primary provider)
SENDGRID_API_KEY=YOUR_SENDGRID_API_KEY
SENDGRID_FROM_EMAIL=noreply@realestateai.com
SENDGRID_FROM_NAME="RealEstate AI"

# SMTP Configuration (backend nodemailer transport uses SendGrid SMTP)
# For development: Use Mailtrap (https://mailtrap.io) - free tier captures emails safely
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_FROM_NAME="RealEstateAI"
SMTP_FROM_EMAIL=noreply@realestateai.com
SMTP_FROM_ADDRESS=noreply@realestateai.com
SMTP_REPLY_TO_EMAIL=support@realestateai.com

# Email Rate Limiting (per recipient)
EMAIL_RATE_LIMIT_WINDOW_MS=3600000
EMAIL_RATE_LIMIT_MAX=10

# 2FA
TWO_FACTOR_AUTHENTICATION_APP_NAME="RealEstateAI"

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000 // 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3000

# Session
SESSION_SECRET=your_session_secret_here

# File Uploads
MAX_FILE_UPLOAD_SIZE=5 // in MB
UPLOAD_PATH=./uploads

# Logging
LOG_LEVEL=debug
LOG_TO_FILE=true
LOG_FILE_PATH=logs/app.log

# API Documentation
SWAGGER_ENABLED=true

# Security
SECURITY_CSRF_ENABLED=true
SECURITY_CSP_ENABLED=true
SECURITY_HSTS_ENABLED=true
SECURITY_XSS_ENABLED=true

# Nginx / SSL
NGINX_HOST=yourdomain.com

# Cache
CACHE_ENABLED=true
CACHE_TTL=3600 // 1 hour

# Feature Flags
FEATURE_EMAIL_VERIFICATION=true
FEATURE_PHONE_VERIFICATION=false
FEATURE_2FA=false

# External Services
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# Stripe (secret key — NEVER expose in frontend)
STRIPE_SECRET_KEY=sk_live_your_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Price IDs (per-plan, used by backend billing service)
# Pricing: Starter $0/mo, Growth $125/mo + $2/unit, Professional $400/mo + $1.50/unit, Enterprise $1264+/mo custom
# Annual discount: 20% (2 months free). Free trial: 14 days.
STRIPE_PRICE_ID_STARTER=YOUR_STRIPE_STARTER_PRICE_ID
STRIPE_PRICE_ID_STARTER_ANNUAL=YOUR_STRIPE_STARTER_ANNUAL_PRICE_ID
STRIPE_PRICE_ID_GROWTH=YOUR_STRIPE_GROWTH_PRICE_ID
STRIPE_PRICE_ID_GROWTH_ANNUAL=YOUR_STRIPE_GROWTH_ANNUAL_PRICE_ID
STRIPE_PRICE_ID_PROFESSIONAL=YOUR_STRIPE_PROFESSIONAL_PRICE_ID
STRIPE_PRICE_ID_PROFESSIONAL_ANNUAL=YOUR_STRIPE_PROFESSIONAL_ANNUAL_PRICE_ID
STRIPE_PRICE_ID_ENTERPRISE=YOUR_STRIPE_ENTERPRISE_PRICE_ID
STRIPE_PRICE_ID_ENTERPRISE_ANNUAL=YOUR_STRIPE_ENTERPRISE_ANNUAL_PRICE_ID
