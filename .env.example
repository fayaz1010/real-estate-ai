# Google OAuth
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Database
DATABASE_URL="postgresql://user:password@host:port/database?schema=public"

# Auth
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=http://localhost:3000

# SMTP Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM=your_email@example.com
SMTP_FROM_EMAIL=noreply@realestateai.com
SMTP_REPLY_TO_EMAIL=support@realestateai.com

# Email Services
SENDGRID_API_KEY=YOUR_SENDGRID_API_KEY
SENDGRID_FROM_EMAIL=noreply@example.com
SENDGRID_FROM_NAME="RealEstate AI"
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe Configuration
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key_here
STRIPE_SECRET_KEY=sk_live_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Price IDs (per-plan, used by backend checkout)
STRIPE_PRICE_ID_STARTER=YOUR_STRIPE_STARTER_PRICE_ID
STRIPE_PRICE_ID_STARTER_ANNUAL=YOUR_STRIPE_STARTER_ANNUAL_PRICE_ID
STRIPE_PRICE_ID_GROWTH=YOUR_STRIPE_GROWTH_PRICE_ID
STRIPE_PRICE_ID_GROWTH_ANNUAL=YOUR_STRIPE_GROWTH_ANNUAL_PRICE_ID
STRIPE_PRICE_ID_PROFESSIONAL=YOUR_STRIPE_PROFESSIONAL_PRICE_ID
STRIPE_PRICE_ID_PROFESSIONAL_ANNUAL=YOUR_STRIPE_PROFESSIONAL_ANNUAL_PRICE_ID
STRIPE_PRICE_ID_ENTERPRISE=YOUR_STRIPE_ENTERPRISE_PRICE_ID
STRIPE_PRICE_ID_ENTERPRISE_ANNUAL=YOUR_STRIPE_ENTERPRISE_ANNUAL_PRICE_ID

# AWS S3
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=your-bucket-name
AWS_S3_BUCKET_URL=https://your-bucket-name.s3.amazonaws.com

# Cloudflare R2
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_ACCESS_KEY_ID=your_cloudflare_access_key_id
CLOUDFLARE_SECRET_ACCESS_KEY=your_cloudflare_secret_access_key
CLOUDFLARE_BUCKET_NAME=your_cloudflare_bucket_name
CLOUDFLARE_BUCKET_URL=your_cloudflare_bucket_url

# Sentry
SENTRY_DSN=your_sentry_dsn

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Facebook OAuth
FACEBOOK_CLIENT_ID=your_facebook_client_id
FACEBOOK_CLIENT_SECRET=your_facebook_client_secret

# Push Notifications
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# Nginx / SSL
NGINX_HOST=localhost
SECURITY_HSTS_ENABLED=true

# Database Backup
DB_BACKUP_DB_NAME=realestate
DB_BACKUP_DB_USER=postgres
DB_BACKUP_DB_PASSWORD=your_db_password_here
DB_BACKUP_PATH=./db_backups
