VITE_API_URL=http://localhost:4041/api
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google OAuth
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# SMTP (Email - SendGrid recommended)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=
SENDGRID_API_KEY=
SMTP_FROM=noreply@realestateai.com
SMTP_FROM_EMAIL=noreply@realestateai.com
SMTP_REPLY_TO_EMAIL=support@realestateai.com

# Stripe
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET

# Stripe Price IDs (per-plan, used by backend checkout)
STRIPE_PRICE_ID_STARTER=YOUR_STRIPE_PRICE_ID_STARTER
STRIPE_PRICE_ID_GROWTH=YOUR_STRIPE_PRICE_ID_GROWTH
STRIPE_PRICE_ID_PROFESSIONAL=YOUR_STRIPE_PRICE_ID_PROFESSIONAL
STRIPE_PRICE_ID_ENTERPRISE=YOUR_STRIPE_PRICE_ID_ENTERPRISE

# Stripe Price IDs (legacy/frontend)
VITE_STRIPE_PRICE_STARTER=price_starter_id_here
VITE_STRIPE_PRICE_PROFESSIONAL=price_professional_id_here
VITE_STRIPE_PRICE_BUSINESS=price_business_id_here
VITE_STRIPE_PRICE_ENTERPRISE=price_enterprise_id_here

# Push Notifications
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# Nginx / SSL
NGINX_HOST=localhost
SECURITY_HSTS_ENABLED=true

# Database Backup
DB_BACKUP_DB_NAME=realestate
DB_BACKUP_DB_USER=postgres
DB_BACKUP_DB_PASSWORD=your_db_password_here
DB_BACKUP_PATH=./db_backups
